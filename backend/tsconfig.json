{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",

    "strict": true,
    "esModuleInterop": true,

    "sourceMap": true,
    "skipLibCheck": true,

    "types": ["node"]
  },

  "include": ["src", "prisma.config.ts"],
  "exclude": ["node_modules", "dist"]
}