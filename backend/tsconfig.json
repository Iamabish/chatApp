{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "target": "ES2020",
    "module": "ES2020",              
    "moduleResolution": "bundler",   
    "strict": true,
    "esModuleInterop": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "types": []
  },
  "include": ["src", "prisma.config.ts"],
  "exclude": ["node_modules", "dist"]
}